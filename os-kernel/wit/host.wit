package webboot:kernel@0.1.0;

interface host {
  type fd = u32;
  type errno = s32;

  record memory-region {
    offset: u32,
    length: u32,
  }

  record ring-layout {
    data: memory-region,
    head-offset: u32,
    tail-offset: u32,
  }

  record gfx-submit {
    queue-id: u32,
    commands: memory-region,
    signal-fence: u64,
  }

  alloc: func(bytes: u32, align: u32) -> memory-region;
  free: func(region: memory-region);

  fd-open: func(path: string, flags: u32) -> fd;
  fd-close: func(handle: fd) -> errno;
  fd-read-at: func(handle: fd, offset: u64, dst: memory-region) -> s32;
  fd-write-at: func(handle: fd, offset: u64, src: memory-region) -> s32;

  gfx-submit-queue: func(request: gfx-submit) -> s32;
  gfx-present: func(surface-id: u32, image-id: u32, wait-fence: u64) -> s32;

  net-send: func(socket-id: u32, src: memory-region) -> s32;
  net-recv: func(socket-id: u32, dst: memory-region) -> s32;

  clock-monotonic-ns: func() -> u64;
}

interface kernel {
  boot: func(total-bytes: u32, ring: ring-layout, flags: u32) -> s32;
  poll: func(deadline-ns: u64) -> s32;
  load-component: func(fd: u32, offset: u64, size: u32) -> s32;
}

world runtime {
  import host;
  export kernel;
}
